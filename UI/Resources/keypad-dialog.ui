<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.3 -->
<interface>
  <!-- interface-name keypad-dialog.ui -->
  <requires lib="gtk" version="4.0"/>
  <!-- Keypad Dialog Template -->
  <object class="GtkDialog" id="keypad_dialog">
    <property name="default-height">300</property>
    <property name="default-width">300</property>
    <property name="modal">true</property>
    <property name="title">Input Value</property>
    <child>
      <!-- Keypad widget placeholder - custom widget implemented in C# -->
      <object class="GtkBox" id="keypad_container">
        <property name="orientation">vertical</property>
      </object>
    </child>
  </object>
</interface>
